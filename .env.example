# Observatorio de Techos Verdes CDMX - Variables de entorno

# Gemini API Key (gratis en https://aistudio.google.com/apikey)
NUXT_GEMINI_API_KEY=

# Modo de datos: 'mock' (default) o 'official'
NUXT_PUBLIC_DATA_MODE=mock

# Google Earth Engine (gratis para investigación/educación)
# 1. Crear proyecto en https://console.cloud.google.com/
# 2. Habilitar Earth Engine API
# 3. Crear Service Account → descargar JSON key
# 4. Registrar SA en https://signup.earthengine.google.com/ (research use)
# 5. Pegar el contenido JSON completo del key file aquí (una línea, escapar comillas)
NUXT_GEE_SERVICE_ACCOUNT_KEY=
NUXT_GEE_PROJECT_ID=

# Sentinel Hub (fallback gratuito, 30k req/mes)
# Registrarse en https://apps.sentinel-hub.com/dashboard/
NUXT_SENTINEL_HUB_CLIENT_ID=
NUXT_SENTINEL_HUB_CLIENT_SECRET=
