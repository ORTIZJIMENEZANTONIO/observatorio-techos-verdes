{"file":"login-BgSRMwi_.js","mappings":";;;;;;;;;;;;;;;;;;;AAGa,iBAAA;AACb,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,WAAW,IAAI,EAAE;AACvB,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,UAAU,IAAI,KAAK;;mBAsBlBA,eAAAC,WAAA,EAAA,OAAM,yEAAA,GAAwE,MAAA,CAAA,mKAGpC,EAAA,oBAAA,mXAAoe,22BAmB9fC,MAAA,KAAA,CAAK,gVAaLA,MAAA,QAAA,CAAQ;UAURA,MAAA,KAAA,GAAK;sVAIXA,MAAA,KAAA,CAAK,CAAA,QAAA;AAAA;;;0DAMCA,MAAA,OAAA,CAAO,IAAA,cAAA,EAAA,8BAAA;UAGPA,MAAA,OAAA,GAAO;;;;;+BAIfA,MAAA,OAAA,IAAO,kBAAA,gBAAA,CAAA,iJAAA;AAAA;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref"],"sources":["../../../../pages/admin/login.vue"],"sourcesContent":["<script setup lang=\"ts\">\ndefinePageMeta({ layout: 'default' })\n\nconst auth = useAuthStore()\nconst email = ref('')\nconst password = ref('')\nconst error = ref('')\nconst loading = ref(false)\n\nasync function handleLogin() {\n  error.value = ''\n  loading.value = true\n  try {\n    await auth.login(email.value, password.value)\n    navigateTo('/admin')\n  } catch (e: any) {\n    error.value = e?.data?.error?.message || 'Error al iniciar sesión'\n  } finally {\n    loading.value = false\n  }\n}\n\nonMounted(() => {\n  auth.loadFromStorage()\n  if (auth.isAuthenticated) navigateTo('/admin')\n})\n</script>\n\n<template>\n  <div class=\"relative flex min-h-[80vh] items-center justify-center overflow-hidden\">\n    <!-- Subtle background pattern -->\n    <div class=\"absolute inset-0 bg-gradient-to-br from-primary-50 via-surface to-white\" />\n    <div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%230E5E3A&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');\" />\n\n    <div class=\"relative z-10 w-full max-w-md px-4\">\n      <div class=\"card p-8 shadow-panel\">\n        <div class=\"mb-6 text-center\">\n          <div class=\"mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary shadow-md transition-transform duration-300 hover:scale-105\">\n            <svg class=\"h-7 w-7 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n            </svg>\n          </div>\n          <h1 class=\"text-xl font-semibold text-ink\">Panel de Administración</h1>\n          <p class=\"mt-1 text-sm text-slate-custom\">Observatorio de Techos Verdes CDMX</p>\n        </div>\n\n        <form @submit.prevent=\"handleLogin\" class=\"space-y-4\">\n          <div>\n            <label for=\"email\" class=\"mb-1 block text-sm font-medium text-ink\">Correo electrónico</label>\n            <input\n              id=\"email\"\n              v-model=\"email\"\n              type=\"email\"\n              required\n              autocomplete=\"email\"\n              class=\"input w-full transition-shadow duration-200 focus:ring-2 focus:ring-primary/20 focus:border-primary\"\n              placeholder=\"admin@observatorio.cdmx\"\n            />\n          </div>\n\n          <div>\n            <label for=\"password\" class=\"mb-1 block text-sm font-medium text-ink\">Contraseña</label>\n            <input\n              id=\"password\"\n              v-model=\"password\"\n              type=\"password\"\n              required\n              autocomplete=\"current-password\"\n              class=\"input w-full transition-shadow duration-200 focus:ring-2 focus:ring-primary/20 focus:border-primary\"\n              placeholder=\"********\"\n            />\n          </div>\n\n          <Transition name=\"slide-up\">\n            <div v-if=\"error\" class=\"flex items-center gap-2 rounded-lg bg-red-50 p-3 text-sm text-red-700\">\n              <svg class=\"h-4 w-4 flex-shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n              </svg>\n              {{ error }}\n            </div>\n          </Transition>\n\n          <button\n            type=\"submit\"\n            :disabled=\"loading\"\n            class=\"btn-primary w-full\"\n          >\n            <svg v-if=\"loading\" class=\"mr-2 h-4 w-4 animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n              <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\" />\n              <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z\" />\n            </svg>\n            {{ loading ? 'Ingresando...' : 'Iniciar sesión' }}\n          </button>\n        </form>\n      </div>\n\n      <p class=\"mt-6 text-center text-xs text-slate-custom/60\">Acceso restringido a administradores autorizados</p>\n    </div>\n  </div>\n</template>\n"],"version":3}